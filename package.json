{
  "name": "codex-orchestrator",
  "version": "0.1.20",
  "description": "Reusable GitHub Issues runner for Codex.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./config/schema": {
      "types": "./dist/src/config/schema.d.ts",
      "import": "./dist/src/config/schema.js"
    }
  },
  "bin": {
    "codex-orchestrator": "dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "prompts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SergiiMytakii/codex-orchestrator.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/test/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke:live": "node scripts/live-smoke.mjs",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  }
}
